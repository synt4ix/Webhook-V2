:root {
  --bg: #0d0f12;
  --panel: #15181d;
  --panel-2: #1b1f26;
  --border: #2a3039;
  --text: #f1f5f9;
  --muted: #9aa4b2;
  --accent: #5865f2;
  --accent-2: #38bdf8;
  --danger: #ef4444;
  --success: #22c55e;
  --warning: #f59e0b;
  --shadow: 0 18px 55px rgba(0, 0, 0, 0.36);
  --radius: 18px;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(88, 101, 242, 0.20), transparent 32rem),
    radial-gradient(circle at bottom right, rgba(56, 189, 248, 0.10), transparent 28rem),
    var(--bg);
  color: var(--text);
}

button,
input,
textarea {
  font: inherit;
}

button {
  border: 0;
  cursor: pointer;
  color: var(--text);
  border-radius: 12px;
  padding: 12px 14px;
  background: var(--panel-2);
  border: 1px solid var(--border);
  transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
}

button:hover {
  transform: translateY(-1px);
  border-color: rgba(88, 101, 242, 0.8);
  background: #202631;
}

button:active {
  transform: translateY(0);
}

.app-shell {
  display: grid;
  grid-template-columns: 360px 1fr;
  min-height: 100vh;
}

.sidebar {
  padding: 28px;
  border-right: 1px solid var(--border);
  background: rgba(15, 18, 23, 0.78);
  backdrop-filter: blur(18px);
}

.brand {
  display: flex;
  gap: 14px;
  align-items: center;
  margin-bottom: 32px;
}

.brand-mark {
  width: 52px;
  height: 52px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
  color: white;
  font-weight: 800;
  box-shadow: var(--shadow);
}

.brand h1,
.topbar h2,
.output-header h2,
.hint-box h2 {
  margin: 0;
}

.brand p,
.topbar p,
.hint-box p {
  margin: 4px 0 0;
  color: var(--muted);
}

.field-label {
  display: block;
  color: var(--muted);
  font-size: 0.9rem;
  margin-bottom: 8px;
}

.input {
  width: 100%;
  padding: 14px 15px;
  color: var(--text);
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 14px;
  outline: none;
}

.input:focus,
textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 4px rgba(88, 101, 242, 0.12);
}

.ghost-button {
  width: 100%;
  margin-top: 10px;
  background: transparent;
}

.ghost-button.small {
  width: auto;
  margin: 0;
  padding: 8px 12px;
}

.button-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 22px;
}

.send-button {
  width: 100%;
  margin-top: 14px;
  background: linear-gradient(135deg, var(--accent), #4752c4);
  border-color: transparent;
  font-weight: 700;
}

.hint-box {
  margin-top: 26px;
  padding: 18px;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  background: rgba(27, 31, 38, 0.76);
}

.hint-box code {
  color: #dbeafe;
  background: rgba(88, 101, 242, 0.18);
  padding: 2px 6px;
  border-radius: 7px;
}

.editor-area {
  padding: 28px;
  display: grid;
  grid-template-rows: auto minmax(420px, 1fr) auto;
  gap: 18px;
}

.topbar,
.output-panel {
  border: 1px solid var(--border);
  background: rgba(21, 24, 29, 0.72);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 22px;
}

.status-pill {
  padding: 8px 12px;
  border-radius: 999px;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border);
}

.status-pill.success {
  color: #bbf7d0;
  border-color: rgba(34, 197, 94, 0.55);
}

.status-pill.error {
  color: #fecaca;
  border-color: rgba(239, 68, 68, 0.55);
}

.status-pill.warning {
  color: #fde68a;
  border-color: rgba(245, 158, 11, 0.55);
}

textarea {
  width: 100%;
  height: 100%;
  resize: none;
  padding: 22px;
  color: #e5e7eb;
  background: #0a0c10;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  outline: none;
  line-height: 1.5;
  font-family: "Cascadia Code", "Fira Code", Consolas, monospace;
  font-size: 14px;
  tab-size: 2;
  box-shadow: var(--shadow);
}

.output-panel {
  padding: 18px;
}

.output-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

pre {
  margin: 0;
  max-height: 240px;
  overflow: auto;
  padding: 16px;
  color: #dbeafe;
  background: #0a0c10;
  border-radius: 14px;
  border: 1px solid var(--border);
  white-space: pre-wrap;
  word-break: break-word;
}

@media (max-width: 980px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .sidebar {
    border-right: 0;
    border-bottom: 1px solid var(--border);
  }

  .editor-area {
    min-height: 900px;
  }
}
